# Database path (SQLite) - relative to working directory
DATABASE_URL=./data/keys.db

# Package storage directory
PACKAGES_DIR=./data/packages

# Server binding
HOST=0.0.0.0
PORT=3000

# Admin portal credentials
ADMIN_USER=admin
ADMIN_PASS_HASH=  # Wrap in single quotes! Generate with: echo -n 'your-password' | argon2 $(openssl rand -base64 16) -id -e

JWT_SECRET=  # openssl rand -base64 64
ACCESS_TOKEN_TTL=30m
REFRESH_TOKEN_TTL=1d

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Branding & VPM listing
BRAND_NAME='oblivius Packages'
VPM_LISTING_ID=dev.oblivius.vpm-oblivius
VPM_LISTING_AUTHOR=oblivius
